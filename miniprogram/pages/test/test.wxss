/* 测试页样式 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1e1b4b 0%, #312e81 200rpx, var(--bg) 500rpx);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
}

.nav-back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 64rpx;
}

.content {
  padding: 0 32rpx 120rpx;
}

/* ====== 步骤指示器 ====== */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0 32rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  transition: all 0.3s;
}

.step.active .step-dot {
  background: #fff;
  color: #4338ca;
}

.step-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.step.active .step-label {
  color: #fff;
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 24rpx;
  margin-bottom: 28rpx;
  border-radius: 2rpx;
}

.step-line.active {
  background: rgba(255, 255, 255, 0.6);
}

/* ====== 类型展示 ====== */
.type-display {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  backdrop-filter: blur(20px);
  margin-bottom: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.type-avatar-wrap {
  flex-shrink: 0;
}

.type-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.1);
}

.type-info-area {
  display: flex;
  flex-direction: column;
}

.type-code {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
}

.type-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.type-motto {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 8rpx;
  font-style: italic;
}

/* ====== 选择方式切换 ====== */
.method-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.method-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  transition: all 0.3s;
}

.method-tab.active {
  background: var(--primary);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.3);
}

/* ====== 开关选择 ====== */
.switch-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.switch-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.switch-label-l,
.switch-label-r {
  font-size: 26rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  width: 130rpx;
  transition: all 0.3s;
}

.switch-label-l {
  text-align: right;
}

.switch-label-r {
  text-align: left;
}

.switch-label-l.active,
.switch-label-r.active {
  color: var(--primary);
  font-weight: 700;
}

.custom-switch {
  width: 108rpx;
  height: 60rpx;
  border-radius: 30rpx;
  position: relative;
  margin: 0 16rpx;
  transition: all 0.3s;
}

.switch-track {
  position: absolute;
  inset: 0;
  border-radius: 30rpx;
  background: #e2e8f0;
  transition: background 0.3s;
}

.custom-switch.on .switch-track {
  background: var(--primary);
}

.switch-thumb {
  position: absolute;
  width: 52rpx;
  height: 52rpx;
  background: #fff;
  border-radius: 26rpx;
  top: 4rpx;
  left: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  z-index: 1;
}

.custom-switch.on .switch-thumb {
  transform: translateX(48rpx);
}

.thumb-letter {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--primary);
}

/* ====== 网格选择 ====== */
.grid-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.grid-group {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.grid-group-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.grid-group-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.grid-types {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 12rpx;
}

.grid-type-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  background: #f8fafc;
  transition: all 0.2s;
}

.grid-type-btn.selected {
  border-color: var(--primary);
  transform: scale(1.02);
}

.grid-type-btn:active {
  transform: scale(0.96);
}

.grid-type-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  margin-bottom: 8rpx;
}

.grid-type-code {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.grid-type-name {
  font-size: 20rpx;
  color: var(--text-secondary);
}

/* ====== 八维认知功能 ====== */
.functions-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  text-align: center;
}

.functions-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.fn-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.fn-item.shadow {
  opacity: 0.5;
}

.fn-position {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.fn-pos-num {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.fn-main {
  flex: 1;
  min-width: 0;
}

.fn-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.fn-code {
  font-size: 30rpx;
  font-weight: 800;
}

.fn-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.fn-pos-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 2rpx;
}

.fn-bar-wrap {
  width: 120rpx;
  height: 12rpx;
  background: #f1f5f9;
  border-radius: 6rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.fn-bar {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* ====== 操作按钮 ====== */
.action-area {
  margin-top: 40rpx;
  padding-bottom: 40rpx;
}

.btn-confirm {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(99, 102, 241, 0.35);
  letter-spacing: 2rpx;
}

.btn-confirm::after {
  border: none;
}

.btn-back-player {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: transparent;
  color: var(--text-secondary);
  font-size: 28rpx;
  border: none;
  margin-bottom: 16rpx;
}

.btn-back-player::after {
  border: none;
}
