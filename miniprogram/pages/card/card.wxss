/* 名片页样式 */
.page {
  min-height: 100vh;
  background: var(--bg);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(180deg, rgba(30, 27, 75, 0.95), rgba(30, 27, 75, 0));
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
}

.nav-back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 64rpx;
}

.content {
  padding: 0 32rpx 120rpx;
}

/* ====== 名片预览 ====== */
.card-preview {
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.2);
}

.card-preview.cosmos {
  background: linear-gradient(145deg, #1e1b4b 0%, #312e81 50%, #4338ca 100%);
}

.card-preview.sunrise {
  background: linear-gradient(145deg, #7c2d12 0%, #c2410c 50%, #fb923c 100%);
}

.card-preview.ocean {
  background: linear-gradient(145deg, #0c4a6e 0%, #0369a1 50%, #38bdf8 100%);
}

.card-preview.forest {
  background: linear-gradient(145deg, #14532d 0%, #15803d 50%, #4ade80 100%);
}

.card-preview.sakura {
  background: linear-gradient(145deg, #831843 0%, #be185d 50%, #f472b6 100%);
}

.card-preview.aurora {
  background: linear-gradient(145deg, #064e3b 0%, #047857 50%, #34d399 100%);
}

/* 用户头像昵称区 */
.card-user-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 12rpx;
}

.card-user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.card-brand {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 32rpx;
}

.card-type-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.1);
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.card-type-code {
  font-size: 64rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 8rpx;
}

.card-type-name {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.card-group-badge {
  margin-top: 16rpx;
  padding: 8rpx 28rpx;
  border-radius: 100rpx;
}

.badge-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
}

.card-motto {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  font-style: italic;
  margin: 24rpx 0;
}

.card-tags {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 32rpx;
}

.card-tag {
  font-size: 24rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.12);
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
}

/* 名片内八维功能 */
.card-functions {
  padding: 24rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.card-fn-title {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-bottom: 20rpx;
}

.card-fn-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-fn-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-fn-item.shadow {
  opacity: 0.4;
}

.card-fn-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
  width: 220rpx;
  flex-shrink: 0;
}

.card-fn-num {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  width: 28rpx;
  text-align: right;
}

.card-fn-code {
  font-size: 28rpx;
  font-weight: 800;
  width: 48rpx;
}

.card-fn-name {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.card-fn-bar-bg {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  overflow: hidden;
}

.card-fn-bar {
  height: 100%;
  border-radius: 8rpx;
  opacity: 0.7;
  transition: width 0.8s ease;
}

.card-quote {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  font-style: italic;
  margin-top: 24rpx;
  line-height: 1.8;
  padding: 0 16rpx;
}

/* ====== 主题选择 ====== */
.theme-section {
  margin-top: 32rpx;
}

.theme-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.theme-scroll {
  display: flex;
  white-space: nowrap;
}

.theme-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.2s;
}

.theme-btn.active {
  border-color: var(--primary);
  box-shadow: 0 4rpx 16rpx rgba(99, 102, 241, 0.2);
}

.theme-preview {
  width: 80rpx;
  height: 48rpx;
  border-radius: 10rpx;
}

.theme-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* Canvas 隐藏 */
.card-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
}

/* ====== 操作按钮 ====== */
.action-area {
  margin-top: 40rpx;
}

.btn-save {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(99, 102, 241, 0.35);
  margin-bottom: 20rpx;
}

.btn-save::after {
  border: none;
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  position: relative;
  flex-shrink: 0;
}

/* 保存图标 - 软盘样式 */
.icon-save {
  border: 2rpx solid #fff;
  border-radius: 4rpx;
}

.icon-save::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 2rpx;
}

.icon-save::after {
  content: '';
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 12rpx;
  border: 2rpx solid #fff;
  border-radius: 2rpx;
  border-bottom: none;
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-share-card,
.btn-invite {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: 2rpx solid var(--primary);
}

.btn-share-card::after,
.btn-invite::after {
  border: none;
}

/* ====== 头像编辑提示 ====== */
.card-user-avatar-wrap {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 12rpx;
}

.card-user-avatar-wrap .card-user-avatar {
  margin-bottom: 0;
}

.avatar-edit-hint {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 0 0 50rpx 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hint-text {
  font-size: 18rpx;
  color: #fff;
}

.card-user-name.placeholder {
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
  font-size: 24rpx;
}
