/* 结果页样式 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1e1b4b 0%, #312e81 200rpx, var(--bg) 500rpx);
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 32rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
}

.nav-back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #fff;
  border-bottom: 4rpx solid #fff;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 64rpx;
}

.content {
  padding: 0 32rpx 120rpx;
}

/* ====== 关系徽章 ====== */
.relation-hero {
  text-align: center;
  padding: 40rpx 24rpx 48rpx;
}

.relation-emoji {
  display: block;
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.relation-name {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 8rpx;
  margin-bottom: 8rpx;
}

.relation-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 20rpx;
}

.stars-row {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 24rpx;
}

.star {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.2);
}

.star.filled {
  color: #fbbf24;
}

.relation-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.8;
  max-width: 560rpx;
  margin: 0 auto;
}

/* ====== 类型对比 ====== */
.vs-section {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.vs-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.vs-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: #f1f5f9;
  margin-bottom: 12rpx;
}

.vs-code {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.vs-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.vs-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 6rpx;
}

.vs-tag {
  font-size: 20rpx;
  color: var(--primary);
  background: rgba(99, 102, 241, 0.08);
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
}

.vs-connector {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 0 8rpx;
}

.vs-line {
  width: 2rpx;
  height: 40rpx;
  background: #e2e8f0;
}

.vs-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vs-badge-text {
  font-size: 32rpx;
}

/* ====== 非对称关系 ====== */
.asymmetric-note {
  display: flex;
  gap: 16rpx;
  background: #fffbeb;
  border: 2rpx solid #fef3c7;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.note-icon {
  font-size: 36rpx;
  flex-shrink: 0;
}

.note-content {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.note-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #92400e;
}

.note-text {
  font-size: 24rpx;
  color: #a16207;
}

/* ====== 深度解读 ====== */
.detail-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.detail-text {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

/* ====== 碰撞总览 ====== */
.collision-summary-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.collision-stats {
  display: flex;
  justify-content: space-around;
}

.collision-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-emoji {
  font-size: 40rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 800;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ====== 功能对比 ====== */
.pairs-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.pairs-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.pair-h-label {
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
}

.pair-h-pos {
  width: 120rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-align: center;
}

.pair-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 12rpx 0;
  border-radius: 16rpx;
}

.pair-row.same {
  background: rgba(16, 185, 129, 0.04);
}

.pair-fn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx;
  border-radius: 12rpx;
}

.pair-fn-code {
  font-size: 32rpx;
  font-weight: 800;
}

.pair-fn-name {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.pair-center {
  width: 120rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.pair-pos-num {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--text-tertiary);
}

.pair-pos-name {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

.pair-match {
  position: absolute;
  top: -4rpx;
  right: 8rpx;
  font-size: 20rpx;
  color: var(--success);
  font-weight: 700;
}

/* ====== 八维碰撞详解 ====== */
.collisions-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
}

.collision-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.collision-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.collision-item.shadow {
  opacity: 0.55;
}

.ci-position {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 80rpx;
}

.ci-pos-num {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.ci-pos-name {
  font-size: 18rpx;
  color: var(--text-tertiary);
  white-space: nowrap;
}

.ci-center {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.ci-fn {
  width: 72rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid;
  border-radius: 10rpx;
  background: #fff;
}

.ci-fn-code {
  font-size: 26rpx;
  font-weight: 800;
}

.ci-collision-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ci-badge-emoji {
  font-size: 22rpx;
}

.ci-type {
  font-size: 24rpx;
  font-weight: 700;
  width: 60rpx;
  text-align: center;
}

/* ====== 操作按钮 ====== */
.action-area {
  margin-top: 40rpx;
}

.btn-share {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(99, 102, 241, 0.35);
  margin-bottom: 20rpx;
}

.btn-share::after {
  border: none;
}

.btn-icon {
  width: 36rpx;
  height: 36rpx;
  position: relative;
}

.icon-share-sm {
  border: 3rpx solid #fff;
  border-radius: 50%;
}

.icon-share-sm::after {
  content: '';
  position: absolute;
  top: -4rpx;
  right: -2rpx;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 10rpx solid #fff;
  transform: rotate(45deg);
}

.btn-row {
  display: flex;
  gap: 16rpx;
}

.btn-sub {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  border: 2rpx solid var(--primary);
}

.btn-sub::after {
  border: none;
}
